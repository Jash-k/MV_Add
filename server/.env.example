# ── Required ──────────────────────────────────────────
# Raw GitHub URL to your M3U playlist file
M3U_URL=https://raw.githubusercontent.com/your-user/your-repo/main/playlist.m3u

# ── Optional ──────────────────────────────────────────
# TMDB API Key for fallback movie details & posters
# Get one free at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Port to run the server on (Render sets this automatically)
PORT=7000

# Render external URL (set automatically on Render, used for keep-alive)
RENDER_EXTERNAL_URL=

# Refresh interval in hours (default: 6)
REFRESH_HOURS=6
