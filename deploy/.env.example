# ═══════════════════════════════════════════════════════════
#  Environment Variables — Stremio M3U Addon
# ═══════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────
# Raw GitHub URL to your M3U playlist file
# ⚠ Must be a raw URL (raw.githubusercontent.com), NOT the GitHub page URL
M3U_URL=https://raw.githubusercontent.com/your-user/your-repo/main/playlist.m3u

# ── OPTIONAL ──────────────────────────────────────────────
# TMDB API Key — fallback for missing posters, descriptions, genres
# Get one FREE at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Port (Render sets this automatically, default 7000 for local dev)
PORT=7000

# Your Render external URL — enables keep-alive self-pinger
# Set this AFTER your first deploy (copy your .onrender.com URL)
# Example: https://stremio-m3u-addon.onrender.com
RENDER_EXTERNAL_URL=

# Refresh interval in hours (default: 6)
REFRESH_HOURS=6
